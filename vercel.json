{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "<https://api.resolvio.xyz/api-docs.json>; rel=\"service-desc\", <https://api.resolvio.xyz/api-docs>; rel=\"service-doc\", </.well-known/mcp.json>; rel=\"describedby\""
        }
      ]
    },
    {
      "source": "/.well-known/api-catalog",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/linkset+json"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
